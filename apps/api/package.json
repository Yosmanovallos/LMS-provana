{
  "name": "@lms/api",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "dev": "ts-node --transpile-only src/main.ts",
    "start": "node dist/main.js",
    "test": "vitest run",
    "lint": "node ../../scripts/check-boundaries.mjs && tsc -p tsconfig.json --noEmit",
    "seed": "ts-node --transpile-only scripts/seed.ts"
  },
  "dependencies": {
    "@lms/contracts": "workspace:*",
    "@nestjs/common": "^11.0.0",
    "@nestjs/core": "^11.0.0",
    "@nestjs/platform-express": "^11.0.0",
    "@nestjs/swagger": "^11.0.0",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.10.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.7.2",
    "vitest": "^2.1.8"
  }
}
